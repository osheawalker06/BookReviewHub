<% content_for :title, "Showing book" %>

<div class="md:w-2/3 w-full">
  <% if notice.present? %>
    <p class="py-2 px-3 bg-green-50 mb-5 text-green-500 font-medium rounded-md inline-block" id="notice"><%= notice %></p>
  <% end %>

  <h1 class="font-bold text-4xl">Showing book</h1>

  <%= render @book %>

  <%= link_to "Edit this book", edit_book_path(@book), class: "w-full sm:w-auto text-center rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
  <%= link_to "Back to books", books_path, class: "w-full sm:w-auto text-center mt-2 sm:mt-0 sm:ml-2 rounded-md px-3.5 py-2.5 bg-gray-100 hover:bg-gray-50 inline-block font-medium" %>
  <%= button_to "Destroy this book", @book, method: :delete, form_class: "sm:inline-block mt-2 sm:mt-0 sm:ml-2", class: "w-full rounded-md px-3.5 py-2.5 text-white bg-red-600 hover:bg-red-500 font-medium cursor-pointer", data: { turbo_confirm: "Are you sure?" } %>
</div>

<div class="mb-10">
    <h2 class="font-bold text-2xl mb-4">Reviews</h2>
    <% if @reviews.any? %>
      <div class="space-y-4">
        <% @reviews.each do |review| %>
          <div class="p-4 border border-gray-100 rounded-lg bg-gray-50/50">
            <div class="text-yellow-500 font-bold mb-1">
              <strong>Rating:</strong> <%= review.rating %>/5 ⭐
            </div>
            <p class="text-gray-700 mb-3"><%= review.comment %></p>

            <div class="flex space-x-3 text-sm">
              <%= link_to "Edit", edit_book_review_path(@book, review), class: "text-blue-600 hover:underline" %>
              <%= button_to "Delete", book_review_path(@book, review), method: :delete, class: "text-red-600 hover:underline cursor-pointer bg-none border-none p-0", data: { turbo_confirm: "Delete this review?" } %>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-gray-500 italic">No reviews yet. Be the first to review this book.</p>
    <% end %>
  </div>

  <div class="bg-white p-6 border border-gray-200 rounded-xl shadow-sm">
    <h2 class="font-bold text-2xl mb-4">Add a Review</h2>

    <%= form_with model: [@book, @review], class: "space-y-4" do |form| %>
      
      <% if @review.errors.any? %>
        <div class="p-4 bg-red-50 text-red-700 rounded-md text-sm">
          <h3 class="font-bold mb-1">Please fix these errors:</h3>
          <ul class="list-disc list-inside">
            <% @review.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= form.label :rating, class: "block font-medium text-gray-700 mb-1" %>
        <%= form.number_field :rating, min: 1, max: 5, class: "rounded-md border border-gray-300 px-3 py-2 w-24 block focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= form.label :comment, class: "block font-medium text-gray-700 mb-1" %>
        <%= form.text_area :comment, rows: 3, class: "rounded-md border border-gray-300 px-3 py-2 w-full block focus:ring-blue-500 focus:border-blue-500" %>
      </div>

      <div>
        <%= form.submit "Submit Review", class: "rounded-md px-4 py-2 text-white bg-blue-600 hover:bg-blue-500 font-medium cursor-pointer" %>
      </div>
    <% end %>
  </div>

</div>
