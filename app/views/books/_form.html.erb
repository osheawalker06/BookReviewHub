<%= form_with(model: book, class: "space-y-5") do |form| %>
  
  <% if book.errors.any? %>
    <div class="p-4 bg-[#F8E9EC] text-[#C06C84] rounded-xl text-sm shadow-sm">
      <h2 class="font-bold mb-1"><%= pluralize(book.errors.count, "error") %> stopped this book from saving:</h2>
      <ul class="list-disc list-inside text-xs space-y-0.5">
        <% book.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= form.label :title, class: "block font-medium text-sm text-gray-500 mb-1" %>
    <%= form.text_field :title, class: "rounded-xl border border-[#EBE5F2] bg-[#F4F1F8]/30 px-4 py-2.5 w-full block focus:ring-2 focus:ring-[#6C5B7B] focus:border-transparent text-sm text-[#4A3B52]" %>
  </div>

  <div>
    <%= form.label :author, class: "block font-medium text-sm text-gray-500 mb-1" %>
    <%= form.text_field :author, class: "rounded-xl border border-[#EBE5F2] bg-[#F4F1F8]/30 px-4 py-2.5 w-full block focus:ring-2 focus:ring-[#6C5B7B] focus:border-transparent text-sm text-[#4A3B52]" %>
  </div>

  <div>
    <%= form.label :description, class: "block font-medium text-sm text-gray-500 mb-1" %>
    <%= form.text_area :description, rows: 4, class: "rounded-xl border border-[#EBE5F2] bg-[#F4F1F8]/30 px-4 py-2.5 w-full block focus:ring-2 focus:ring-[#6C5B7B] focus:border-transparent text-sm text-[#4A3B52]" %>
  </div>

  <div>
    <%= form.label :genre, class: "block font-medium text-sm text-gray-500 mb-1" %>
    <%= form.text_field :genre, class: "rounded-xl border border-[#EBE5F2] bg-[#F4F1F8]/30 px-4 py-2.5 w-full block focus:ring-2 focus:ring-[#6C5B7B] focus:border-transparent text-sm text-[#4A3B52]" %>
  </div>

  <div>
    <%= form.label :isbn, "ISBN", class: "block font-medium text-sm text-gray-500 mb-1" %>
    <%= form.text_field :isbn, class: "rounded-xl border border-[#EBE5F2] bg-[#F4F1F8]/30 px-4 py-2.5 w-full block focus:ring-2 focus:ring-[#6C5B7B] focus:border-transparent text-sm text-[#4A3B52]" %>
  </div>

  <div>
    <%= form.label :cover_url, "Cover URL", class: "block font-medium text-sm text-gray-500 mb-1" %>
    <%= form.text_field :cover_url, class: "rounded-xl border border-[#EBE5F2] bg-[#F4F1F8]/30 px-4 py-2.5 w-full block focus:ring-2 focus:ring-[#6C5B7B] focus:border-transparent text-sm text-[#4A3B52]" %>
  </div>

  <div class="pt-4 flex flex-wrap items-center gap-2 border-t border-gray-100">
    
    <%= form.submit class: "rounded-xl px-4 py-2.5 text-sm text-white bg-[#6C5B7B] hover:bg-[#574964] font-medium shadow-sm cursor-pointer transition flex-shrink-0" %>
    
    <% if book.persisted? %>
      <%= link_to "Show this book", book, class: "rounded-xl px-4 py-2.5 text-sm text-[#6C5B7B] bg-[#EBE5F2] hover:bg-[#DFD5E7] font-medium text-center transition" %>
    <% end %>
    
    <%= link_to "Back to books", books_path, class: "rounded-xl px-4 py-2.5 text-sm text-gray-500 bg-gray-100 hover:bg-gray-200 font-medium text-center transition" %>
  
  </div>

<% end %>