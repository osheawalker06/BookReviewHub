<div class="max-w-md mx-auto bg-white rounded-2xl p-6 md:p-8 shadow-sm border border-[#EBE5F2] my-12">
  <h2 class="font-serif font-bold text-2xl text-[#4A3B52] text-center mb-2">Recover Your Keys</h2>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post, class: "space-y-5" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div>
      <%= f.label :email, class: "block text-xs font-semibold text-[#6C5B7B] uppercase tracking-wide mb-1" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "w-full rounded-xl border border-[#EBE5F2] px-4 py-2.5 text-sm focus:outline-none focus:ring-2 focus:ring-[#6C5B7B]/20 focus:border-[#6C5B7B] transition bg-[#F4F1F8]/30" %>
    </div>

    <div>
      <%= f.submit "Send Reset Instructions", class: "w-full text-center block text-xs font-semibold tracking-wide uppercase rounded-xl py-3 bg-[#6C5B7B] hover:bg-[#5A4B69] text-white shadow-sm transition cursor-pointer" %>
    </div>
  <% end %>

  <div class="mt-6 pt-6 border-t border-[#EBE5F2] text-center text-xs text-gray-500 space-y-1">
    <%= render "devise/shared/links" %>
  </div>
</div>